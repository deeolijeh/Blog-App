rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Match the posts collection
    match /posts/{postId} {
      allow read: if true;
      
      // Creation: must be logged in and set authorId to their own UID
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      
      // Update/Delete: must be the original author
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;

      // Likes subcollection
      match /likes/{userId} {
        allow read: if true;
        // Users can only write (create/delete) their own like document
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
        
        // Allow delete if the user is the comment author OR the owner of the parent post
        allow delete: if request.auth != null && (resource.data.authorId == request.auth.uid || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
        allow update: if request.auth != null && resource.data.authorId == request.auth.uid;
      }
    }
  }
}